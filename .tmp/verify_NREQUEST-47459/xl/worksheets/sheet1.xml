<?xml version="1.0" encoding="UTF-8" standalone="yes"?><worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"><dimension ref="A1:N10"/><sheetViews><sheetView workbookViewId="0"/></sheetViews><sheetFormatPr defaultRowHeight="18"/><cols><col min="1" max="14" width="24" customWidth="1"/></cols><sheetData><row r="1"><c r="A1" t="inlineStr"><is><t xml:space="preserve">STORY编号</t></is></c><c r="B1" t="inlineStr"><is><t xml:space="preserve">节点路径</t></is></c><c r="C1" t="inlineStr"><is><t xml:space="preserve">测试用例名称</t></is></c><c r="D1" t="inlineStr"><is><t xml:space="preserve">摘要</t></is></c><c r="E1" t="inlineStr"><is><t xml:space="preserve">前置条件</t></is></c><c r="F1" t="inlineStr"><is><t xml:space="preserve">执行步骤</t></is></c><c r="G1" t="inlineStr"><is><t xml:space="preserve">预期结果</t></is></c><c r="H1" t="inlineStr"><is><t xml:space="preserve">实际结果</t></is></c><c r="I1" t="inlineStr"><is><t xml:space="preserve">优先级</t></is></c><c r="J1" t="inlineStr"><is><t xml:space="preserve">作者</t></is></c><c r="K1" t="inlineStr"><is><t xml:space="preserve">类型</t></is></c><c r="L1" t="inlineStr"><is><t xml:space="preserve">是否需要回归</t></is></c><c r="M1" t="inlineStr"><is><t xml:space="preserve">应用</t></is></c><c r="N1" t="inlineStr"><is><t xml:space="preserve">标签</t></is></c></row><row r="2"><c r="A2" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B2" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/清退申请</t></is></c><c r="C2" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超风险清退用户发起授信信息变更申请成功</t></is></c><c r="D2" t="inlineStr"><is><t xml:space="preserve">验证风险发起清退后，APS通过5.1.4授信信息变更申请向蚂蚁发起风险清退</t></is></c><c r="E2" t="inlineStr"><is><t xml:space="preserve">渠道: 蚂蚁贷超；存在已授信且可清退用户；蚂蚁侧清退限量未超2000/月；清退类型为风险清退RISK_CLEAR</t></is></c><c r="F2" t="inlineStr"><is><t xml:space="preserve">1. 构造风险清退用户数据；2. 触发风险清退通知APS；3. 调用5.1.4授信信息变更申请接口ant.loanmarket.credit.loan.institution.info.change.apply；4. 请求中传入changeReqNo、creditProdCode、清退类型RISK_CLEAR，并保持授信额度不变、授信状态由正常变为失效</t></is></c><c r="G2" t="inlineStr"><is><t xml:space="preserve">5.1.4接口返回受理成功，resultInfo.resultCode=0000；返回applyNo/changeReqNo可用于后续5.1.5结果通知关联；APS记录清退申请已发送蚂蚁</t></is></c><c r="H2" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I2" t="inlineStr"><is><t xml:space="preserve">高</t></is></c><c r="J2" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K2" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L2" t="inlineStr"><is><t xml:space="preserve">是</t></is></c><c r="M2" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N2" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,5.1.4,风险清退</t></is></c></row><row r="3"><c r="A3" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B3" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/结果通知</t></is></c><c r="C3" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超清退结果通知成功后回传风险成功</t></is></c><c r="D3" t="inlineStr"><is><t xml:space="preserve">验证蚂蚁通过5.1.5返回清退成功，APS同步告知风险</t></is></c><c r="E3" t="inlineStr"><is><t xml:space="preserve">已通过5.1.4发起清退申请并获得applyNo/changeReqNo；蚂蚁侧完成内部校验且清退成功</t></is></c><c r="F3" t="inlineStr"><is><t xml:space="preserve">1. 调用5.1.5授信信息变更结果接口ant.loanmarket.credit.loan.institution.info.change.result；2. 请求中传入与5.1.4一致的applyNo/changeReqNo；3. changeResult传Y；4. APS处理结果通知并回传风险</t></is></c><c r="G3" t="inlineStr"><is><t xml:space="preserve">5.1.5接口返回受理成功，resultInfo.resultCode=0000；APS将清退最终结果通知风险；风险侧清退状态与蚂蚁侧保持一致</t></is></c><c r="H3" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I3" t="inlineStr"><is><t xml:space="preserve">高</t></is></c><c r="J3" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K3" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L3" t="inlineStr"><is><t xml:space="preserve">是</t></is></c><c r="M3" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N3" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,5.1.5,成功通知</t></is></c></row><row r="4"><c r="A4" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B4" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/结果通知</t></is></c><c r="C4" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超清退结果通知拒绝后回传风险失败原因</t></is></c><c r="D4" t="inlineStr"><is><t xml:space="preserve">验证蚂蚁清退拒绝时，APS保存并回传拒绝原因</t></is></c><c r="E4" t="inlineStr"><is><t xml:space="preserve">已通过5.1.4发起清退申请并获得applyNo/changeReqNo；蚂蚁侧返回拒绝结果</t></is></c><c r="F4" t="inlineStr"><is><t xml:space="preserve">1. 调用5.1.5授信信息变更结果接口；2. changeResult传N；3. 传入changeResultReasonCode和changeResultReasonMsg；4. APS处理拒绝结果并回传风险</t></is></c><c r="G4" t="inlineStr"><is><t xml:space="preserve">5.1.5接口返回受理成功，resultInfo.resultCode=0000；APS记录changeResult=N及拒绝原因码/原因描述；风险侧收到清退失败结果及原因</t></is></c><c r="H4" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I4" t="inlineStr"><is><t xml:space="preserve">中</t></is></c><c r="J4" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K4" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L4" t="inlineStr"><is><t xml:space="preserve">否</t></is></c><c r="M4" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N4" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,5.1.5,拒绝通知</t></is></c></row><row r="5"><c r="A5" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B5" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/幂等</t></is></c><c r="C5" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超重复清退结果通知保持幂等</t></is></c><c r="D5" t="inlineStr"><is><t xml:space="preserve">验证同一applyNo重复调用5.1.5不会造成重复处理或状态回退</t></is></c><c r="E5" t="inlineStr"><is><t xml:space="preserve">同一applyNo/changeReqNo已有一次5.1.5清退结果处理记录</t></is></c><c r="F5" t="inlineStr"><is><t xml:space="preserve">1. 使用相同applyNo/changeReqNo重复调用5.1.5授信信息变更结果接口；2. 保持changeResult与首次一致；3. 查询APS处理记录和风险通知记录</t></is></c><c r="G5" t="inlineStr"><is><t xml:space="preserve">5.1.5接口返回受理成功或幂等成功，resultInfo.resultCode=0000；APS不重复生成冲突状态；风险侧不出现重复或相互矛盾的清退通知</t></is></c><c r="H5" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I5" t="inlineStr"><is><t xml:space="preserve">中</t></is></c><c r="J5" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K5" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L5" t="inlineStr"><is><t xml:space="preserve">否</t></is></c><c r="M5" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N5" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,幂等,5.1.5</t></is></c></row><row r="6"><c r="A6" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B6" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/异常校验</t></is></c><c r="C6" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超授信信息变更申请必填参数缺失返回参数错误</t></is></c><c r="D6" t="inlineStr"><is><t xml:space="preserve">验证5.1.4缺失必填字段时不受理清退申请</t></is></c><c r="E6" t="inlineStr"><is><t xml:space="preserve">渠道: 蚂蚁贷超；准备一笔清退申请，但缺失creditProdCode、applyNo或changeReqNo等必填字段之一</t></is></c><c r="F6" t="inlineStr"><is><t xml:space="preserve">1. 构造缺失必填字段的5.1.4授信信息变更申请报文；2. 调用ant.loanmarket.credit.loan.institution.info.change.apply接口；3. 检查接口响应和APS记录</t></is></c><c r="G6" t="inlineStr"><is><t xml:space="preserve">5.1.4接口返回参数错误，resultInfo.resultCode=0011；不生成有效清退申请；APS不向风险回传清退成功</t></is></c><c r="H6" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I6" t="inlineStr"><is><t xml:space="preserve">中</t></is></c><c r="J6" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K6" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L6" t="inlineStr"><is><t xml:space="preserve">否</t></is></c><c r="M6" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N6" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,异常校验,5.1.4</t></is></c></row><row r="7"><c r="A7" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B7" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/月限量</t></is></c><c r="C7" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超清退月限量超2000走线下评估后再清退</t></is></c><c r="D7" t="inlineStr"><is><t xml:space="preserve">验证蚂蚁侧清退月限量规则被纳入测试，超限用户不直接线上清退</t></is></c><c r="E7" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超当月清退量已达到2000；存在额外高风险待清退用户</t></is></c><c r="F7" t="inlineStr"><is><t xml:space="preserve">1. 尝试对超出月限量的用户发起清退；2. 检查是否按需求要求走商务/线下评估；3. 蚂蚁打开限量后再发起线上5.1.4清退申请</t></is></c><c r="G7" t="inlineStr"><is><t xml:space="preserve">超限时不直接完成线上清退；线下评估通过且蚂蚁打开限量后，5.1.4清退申请可正常受理</t></is></c><c r="H7" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I7" t="inlineStr"><is><t xml:space="preserve">中</t></is></c><c r="J7" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K7" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L7" t="inlineStr"><is><t xml:space="preserve">否</t></is></c><c r="M7" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N7" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,月限量</t></is></c></row><row r="8"><c r="A8" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B8" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/日终对账</t></is></c><c r="C8" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超清退用户日终授信对账文件字段正确</t></is></c><c r="D8" t="inlineStr"><is><t xml:space="preserve">验证清退用户在日终授信对账文件中的账户状态、授信状态和额度符合需求</t></is></c><c r="E8" t="inlineStr"><is><t xml:space="preserve">存在已清退成功用户；日终授信对账文件已生成</t></is></c><c r="F8" t="inlineStr"><is><t xml:space="preserve">1. 获取清退成功用户的日终授信对账文件记录；2. 核对credit_account_no、credit_prod_code定位到目标用户；3. 检查acct_status、credit_status、credit_amt字段</t></is></c><c r="G8" t="inlineStr"><is><t xml:space="preserve">日终授信对账文件中清退用户acct_status=正常，credit_status=失效，credit_amt授信额度不变；gl_date与文件生成日期一致</t></is></c><c r="H8" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I8" t="inlineStr"><is><t xml:space="preserve">高</t></is></c><c r="J8" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K8" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L8" t="inlineStr"><is><t xml:space="preserve">是</t></is></c><c r="M8" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N8" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,日终对账,文件校验</t></is></c></row><row r="9"><c r="A9" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B9" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/贷中拦截</t></is></c><c r="C9" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超清退成功用户不再发起奇富借款</t></is></c><c r="D9" t="inlineStr"><is><t xml:space="preserve">验证清退成功后蚂蚁侧不再将该用户发起交易至我方</t></is></c><c r="E9" t="inlineStr"><is><t xml:space="preserve">用户已完成风险清退且蚂蚁侧清退结果为成功；未到授信拒绝180天后重新分发场景</t></is></c><c r="F9" t="inlineStr"><is><t xml:space="preserve">1. 使用清退成功用户在蚂蚁侧尝试借款/动用；2. 观察是否有奇富借款申请进入我方；3. 检查APS或入口日志是否存在该用户借款请求</t></is></c><c r="G9" t="inlineStr"><is><t xml:space="preserve">清退成功用户不再发起奇富借款至我方；APS侧无该用户新的借款申请请求；如已超过授信拒绝180天重新分发，需按单独规则评估</t></is></c><c r="H9" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I9" t="inlineStr"><is><t xml:space="preserve">高</t></is></c><c r="J9" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K9" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L9" t="inlineStr"><is><t xml:space="preserve">是</t></is></c><c r="M9" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N9" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,借款拦截</t></is></c></row><row r="10"><c r="A10" t="inlineStr"><is><t xml:space="preserve">NREQUEST-47459</t></is></c><c r="B10" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超/贷中清退/动用前查询</t></is></c><c r="C10" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超动用前查询清退用户额度状态为失效</t></is></c><c r="D10" t="inlineStr"><is><t xml:space="preserve">验证20260615补充说明中动用前查询清退用户，额度状态与文件保持一致</t></is></c><c r="E10" t="inlineStr"><is><t xml:space="preserve">存在清退成功用户；日终文件中该用户credit_status=失效</t></is></c><c r="F10" t="inlineStr"><is><t xml:space="preserve">1. 在蚂蚁侧动用前查询清退用户；2. 获取额度/授信状态返回；3. 与日终授信对账文件中的credit_status比对</t></is></c><c r="G10" t="inlineStr"><is><t xml:space="preserve">蚂蚁侧动用前查询返回额度状态为失效；状态与日终授信对账文件credit_status=失效保持一致</t></is></c><c r="H10" t="inlineStr"><is><t xml:space="preserve"></t></is></c><c r="I10" t="inlineStr"><is><t xml:space="preserve">中</t></is></c><c r="J10" t="inlineStr"><is><t xml:space="preserve">Codex</t></is></c><c r="K10" t="inlineStr"><is><t xml:space="preserve">功能测试</t></is></c><c r="L10" t="inlineStr"><is><t xml:space="preserve">否</t></is></c><c r="M10" t="inlineStr"><is><t xml:space="preserve">APS</t></is></c><c r="N10" t="inlineStr"><is><t xml:space="preserve">蚂蚁贷超,贷中清退,动用前查询,状态一致性</t></is></c></row></sheetData><pageMargins left="0.7" right="0.7" top="0.75" bottom="0.75" header="0.3" footer="0.3"/></worksheet>
